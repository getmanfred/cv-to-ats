# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is already in .gitignore.

# AI provider (NaN API — https://nan.builders)
NAN_API_KEY=

# Supabase — use project URL and service role key (not the anon key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin panel credentials
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SECRET=

# Optional: base URL for OG image generation (defaults to Railway URL if not set)
# NEXT_PUBLIC_BASE_URL=https://your-domain.com
